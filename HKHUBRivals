-- Layout automático
local function criarLayout(frame)
	local padding = Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 8)
	padding.PaddingLeft = UDim.new(0, 8)
	padding.PaddingRight = UDim.new(0, 8)
	padding.Parent = frame

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 8)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = frame
end

criarLayout(vantagensFrame)
criarLayout(zoeirasFrame)

-- Alternância de abas
tabVantagens.MouseButton1Click:Connect(function()
	vantagensFrame.Visible = true
	zoeirasFrame.Visible = false
end)

tabZoeiras.MouseButton1Click:Connect(function()
	vantagensFrame.Visible = false
	zoeirasFrame.Visible = true
end)

-- Criador de botões
local function criarBotao(frame, nome, descricao, cor)
	local itemFrame = Instance.new("Frame")
	itemFrame.Size = UDim2.new(1, -10, 0, 60)
	itemFrame.BackgroundColor3 = cor
	itemFrame.BorderSizePixel = 0
	itemFrame.Parent = frame

	local itemCorner = Instance.new("UICorner")
	itemCorner.CornerRadius = UDim.new(0, 6)
	itemCorner.Parent = itemFrame

	local label = Instance.new("TextLabel")
	label.Text = nome .. " - " .. descricao
	label.Size = UDim2.new(0.7, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1,1,1)
	label.TextScaled = true
	label.Parent = itemFrame

	local botao = Instance.new("TextButton")
	botao.Text = "Ativar"
	botao.Size = UDim2.new(0.2, 0, 0.7, 0)
	botao.Position = UDim2.new(0.75, 0, 0.15, 0)
	botao.BackgroundColor3 = Color3.fromRGB(255,255,255)
	botao.TextColor3 = Color3.fromRGB(0,0,0)
	botao.Parent = itemFrame

	local botaoCorner = Instance.new("UICorner")
	botaoCorner.CornerRadius = UDim.new(0, 6)
	botaoCorner.Parent = botao

	botao.MouseButton1Click:Connect(function()
		print(nome .. " ativado!")
	end)
end

-- Vantagens
criarBotao(vantagensFrame, "Radar do Zé Curioso", "Mostra inimigos próximos", Color3.fromRGB(80, 200, 120))
criarBotao(vantagensFrame, "Auto-Tiro 3000", "Dispara automaticamente", Color3.fromRGB(80, 200, 120))

